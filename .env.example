# MatchFlow AI — safe local/demo template. Do not commit real secrets.

# App
APP_ENV=local
ENVIRONMENT=development
APP_MODE=PAPER_TRADING_SIMULATION_ONLY
DEMO_MODE=true
API_HOST=127.0.0.1
API_PORT=8000
MATCHFLOW_LOG_TO_FILE=false

# Security/Auth
AUTH_MODE=saas
AUTH_ENABLED=true
AUTH_DATABASE_URL=data/auth/matchflow_auth.sqlite3
AUTH_TOKEN_EXPIRATION_MINUTES=60
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=14
AUTH_PUBLIC_REGISTRATION_ENABLED=true
AUTH_SECURE_COOKIES=false
PASSWORD_MIN_LENGTH=8

# Email Verification
EMAIL_VERIFICATION_ENABLED=false
# When EMAIL_VERIFICATION_ENABLED=false, users can use the app normally and verification_pending_optional=true.
# When true, configure your mail provider and apply verification gates for sensitive actions.

# Database
DATABASE_URL=sqlite:///data/auth/matchflow_auth.sqlite3
# Production example: postgresql+psycopg2://user:password@host:5432/matchflow

# Storage
MATCHFLOW_DISABLE_PARQUET=0
TENANT_STORAGE_ROOT=data/tenants

# Data Engine
DATA_ENGINE_MODE=internal
DATA_ENGINE_PRIMARY_PROVIDER=flashscore
DATA_ENGINE_EXTERNAL_PATH=
MATCH_TIME_TOLERANCE_HOURS=24

# FlashScore
FLASHSCORE_ENABLED=true
FLASHSCORE_USE_DEMO=false
FLASHSCORE_HEADLESS=true
FLASHSCORE_TEST_MODE=true
FLASHSCORE_MAX_LEAGUES=5
FLASHSCORE_START_DATE=2023-01-01
FLASHSCORE_END_DATE=yesterday
FLASHSCORE_SLEEP_SECONDS=0.5
FLASHSCORE_TIMEOUT_SECONDS=30
FLASHSCORE_BATCH_SIZE=20
MATCHFLOW_FLASH_SCORE_VALIDATE_LIVE=0

# Football-Data.org
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_LEAGUES=PL,BL1,SA,PD,BSA
FOOTBALL_DATA_SEASONS=2023,2024,2025

# Odds API
ODDS_API_KEY=
ODDS_REGIONS=eu
ODDS_MARKETS=h2h,totals,btts
ODDS_BOOKMAKERS=pinnacle,betfair,bet365

# Groq Entity Resolution
ENTITY_RESOLUTION_USE_LLM=false
ENTITY_RESOLUTION_LLM_PROVIDER=groq
ENTITY_RESOLUTION_LLM_THRESHOLD=82
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile


# Telegram Bot (opcional — alertas de candidatos HIGH_CONFIDENCE)
# Crie um bot com @BotFather e obtenha o token
# Descubra seu chat_id: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_SCORE=70
# ML/Monitoring
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
INITIAL_BANKROLL=1000.0
BANKROLL_PROFILE=Balanced
KELLY_FRACTION=0.25
MAX_STAKE_PCT=0.05
MAX_DAILY_EXPOSURE_PCT=0.20
MONTHLY_DRAWDOWN_STOP=0.25

# Scheduler
SCHEDULER_RUN_HOURS=7,13,19
SCHEDULER_TIMEZONE=America/Sao_Paulo

# Demo
ENABLE_DEMO_ACCOUNTS=true
DEMO_ACCOUNTS_ALLOWED_ENV=development,demo,local
DISABLE_DEMO_ACCOUNTS_IN_PRODUCTION=true

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1):51[0-9]{2}

# Production
# APP_ENV=production
# ENVIRONMENT=production
# AUTH_SECURE_COOKIES=true
# ENABLE_DEMO_ACCOUNTS=false
# DISABLE_DEMO_ACCOUNTS_IN_PRODUCTION=true
# CORS_ORIGINS=https://your-frontend-domain.example
